[Unit]
Description=Hallowdeep score server
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/seanstarkey.dev/public/Hallowdeep
Environment=NODE_ENV=production
Environment=PORT=3000
ExecStart=/usr/bin/node /var/www/seanstarkey.dev/public/Hallowdeep/server.js
Restart=on-failure
RestartSec=5

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/www/seanstarkey.dev/public/Hallowdeep/data

[Install]
WantedBy=multi-user.target
